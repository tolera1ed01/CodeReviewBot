PORT=3000

# GitHub — create a Personal Access Token with repo + pull_requests scope
GITHUB_TOKEN=ghp_...
# Set this when creating the webhook in GitHub repo settings
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Gemini — https://aistudio.google.com/apikey (free tier available)
GEMINI_API_KEY=your_gemini_api_key

# Upstash Redis — free tier at https://console.upstash.com/
# Create a Redis database, then copy the REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
